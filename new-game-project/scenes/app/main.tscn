[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/ui/main_app.gd" id="1"]
[ext_resource type="PackedScene" path="res://scenes/components/toast.tscn" id="2"]

[node name="Main" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Root" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Header" type="PanelContainer" parent="Root"]
layout_mode = 2
size_flags_horizontal = 3

[node name="Title" type="Label" parent="Root/Header"]
layout_mode = 2
text = "Landscaping Ops Portal"
horizontal_alignment = 1

[node name="Content" type="VBoxContainer" parent="Root"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3

[node name="BottomNav" type="GridContainer" parent="Root"]
layout_mode = 2
columns = 3

[node name="DashboardButton" type="Button" parent="Root/BottomNav"]
layout_mode = 2
text = "Dashboard"

[node name="EmployeesButton" type="Button" parent="Root/BottomNav"]
layout_mode = 2
text = "Employees"

[node name="TimeButton" type="Button" parent="Root/BottomNav"]
layout_mode = 2
text = "Time"

[node name="InventoryButton" type="Button" parent="Root/BottomNav"]
layout_mode = 2
text = "Inventory"

[node name="EquipmentButton" type="Button" parent="Root/BottomNav"]
layout_mode = 2
text = "Equipment"

[node name="JobsButton" type="Button" parent="Root/BottomNav"]
layout_mode = 2
text = "Jobs"

[node name="Toast" parent="." instance=ExtResource("2")]
unique_name_in_owner = true

[connection signal="pressed" from="Root/BottomNav/DashboardButton" to="." method="_on_tab_pressed" binds= ["Dashboard"]]
[connection signal="pressed" from="Root/BottomNav/EmployeesButton" to="." method="_on_tab_pressed" binds= ["Employees"]]
[connection signal="pressed" from="Root/BottomNav/TimeButton" to="." method="_on_tab_pressed" binds= ["Time"]]
[connection signal="pressed" from="Root/BottomNav/InventoryButton" to="." method="_on_tab_pressed" binds= ["Inventory"]]
[connection signal="pressed" from="Root/BottomNav/EquipmentButton" to="." method="_on_tab_pressed" binds= ["Equipment"]]
[connection signal="pressed" from="Root/BottomNav/JobsButton" to="." method="_on_tab_pressed" binds= ["Jobs"]]
